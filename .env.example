# === Chave da OpenAI para gerar a arte do jogo ===
# 1) Crie sua chave em: https://platform.openai.com/api-keys
# 2) Renomeie ESTE arquivo para ".env" (sem o ".example")
# 3) Cole a chave abaixo. Ela fica só no seu PC: o .env é ignorado pelo git
#    e nunca deve ser colado no chat.
OPENAI_API_KEY=sk-cole-sua-chave-aqui

# Qualidade da imagem: low | medium | high   (premium = high)
ARTE_QUALIDADE=high

# (opcional) tamanho: 1024x1024 | 1024x1536 | 1536x1024
ARTE_SIZE=1024x1024
